# ============================================
# CRM AI First - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ------------------------------------------
# FRONTEND (obrigatorio)
# ------------------------------------------
# URL do seu projeto Supabase (ex: https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=
# Anon/Publishable key do Supabase (encontre em Settings > API)
VITE_SUPABASE_PUBLISHABLE_KEY=

# ------------------------------------------
# EDGE FUNCTIONS - Chaves de API
# ------------------------------------------
# IMPORTANTE: Estas chaves podem ser configuradas de duas formas:
# 1. Pela UI: Settings > Integracoes (recomendado)
# 2. Via CLI: npx supabase secrets set NOME=valor --project-ref SEU_REF
#
# Se configurar pela UI, NAO precisa configurar aqui.
# A UI tem prioridade sobre as variaveis de ambiente.

# IA / LLM - OpenAI (usado em analyze-lead, analyze-sales-call, marketing-copilot, etc)
# OPENAI_API_KEY=

# IA / Agente de Vendas - Anthropic Claude (usado no ai-sales-agent)
# ANTHROPIC_API_KEY=

# WhatsApp via UAZAPI (usado em uazapi-*, send-candidate-whatsapp)
# UAZAPI_SUBDOMAIN=
# UAZAPI_ADMIN_TOKEN=

# Chamadas VoIP (usado em get-wavoip-token)
# WAVOIP_TOKEN=

# Transcricao de audio (usado em get-soniox-token)
# SONIOX_API_KEY=

# Enriquecimento de Instagram (usado em enrich-instagram)
# RAPIDAPI_KEY=

# Google Meet para entrevistas (usado em create-meet-interview)
# GOOGLE_SERVICE_ACCOUNT_JSON=
